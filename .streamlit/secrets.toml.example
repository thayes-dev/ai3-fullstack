# Streamlit Community Cloud Secrets — Phoenix only.
#
# Anthropic and Voyage keys are entered by visitors via the sidebar
# (anti-credit-burn pattern from Session 4.1).
#
# How to use:
#   1. share.streamlit.io  →  Your app  →  Settings  →  Secrets
#   2. Paste the three lines below, with your real values.
#   3. Save. The app restarts automatically.
#
# DO NOT commit a real secrets.toml to the repo — it would expose
# the shared Phoenix key to anyone who clones.

PHOENIX_API_KEY = "<paste-instructor-shared-key>"
PHOENIX_COLLECTOR_ENDPOINT = "https://app.phoenix.arize.com/s/tyler-hayes"
PHOENIX_PROJECT_NAME = "ai3-<your-handle>"
