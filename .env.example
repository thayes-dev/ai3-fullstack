# AI-3: Full Stack AI Engineering
# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# Anthropic API Key (required — Session 1.1+)
# Get yours at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Voyage AI API Key (required — Session 1.1+)
# Get yours at: https://dash.voyageai.com → API Keys
VOYAGE_API_KEY=pa-your-key-here

# Phoenix / Arize (required — Session 1.1+)
# Your instructor has added you to Phoenix Cloud.
# Log in at: https://app.phoenix.arize.com
# Create a System Key at: Settings → API Keys
PHOENIX_API_KEY=your-phoenix-api-key-here
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_PROJECT_NAME=ai3-your-handle
